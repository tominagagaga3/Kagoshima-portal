---
import { getImage } from "astro:assets";
import prevDecorationImg from "../../../assets/key-images/prev-decoration.png";
const prevDecorationImgSrc = await getImage({ src: prevDecorationImg });

import type { WpPost } from "../../../lib/wp/types";
import { featuredImageUrl } from "../../../lib/wp/client";

export interface Props {
  posts: WpPost[];
  idPrefix: string; 
}
const { posts = [] } = Astro.props;

const base = posts.filter(Boolean);

const loopSlides =
  base.length >= 2
    ? [base[base.length - 1], ...base, base[0]]
    : base.length === 1
      ? [base[0], base[0], base[0]] 
      : [];


const { idPrefix } = Astro.props;
const slideId = `${idPrefix}-slide`;
const prevId = `${idPrefix}-prev`;
const nextId = `${idPrefix}-next`;
---


{loopSlides.length > 0 && (
  <div class="slide-wrapper">
    <div
      id={slideId}
      class="slide"
      data-step={`${100 / loopSlides.length}`}
    >
      {loopSlides.map((p, i) => {
        const img = featuredImageUrl(p, "medium");
        const isDummy = base.length >= 2 ? (i === 0 || i === loopSlides.length - 1) : false;

        return (
          <div class="article-wrapper" data-dummy={isDummy ? "1" : "0"}>
            <div class="contents">
            <a class="card" href={`/posts/${p.slug}`}>
              <div class="card-contents">
              {img ? (
                <img src={img} alt={p.title.rendered} loading="lazy" />
              ) : (
                <div class="dummy" />
              )}
              <div class="textarea">
                <div class="date">{new Date(p.date).toLocaleDateString("ja-JP")}</div>
                <h2 set:html={p.title.rendered} />
                <div class="excerpt">{p.meta?.top_text ?? "aaa"}</div>
                
              </div>
              </div>
            </a>
            </div>
          </div>
        );
      })}
    </div>

    <span id={prevId} class="prev" aria-label="前へ"></span>
    <span id={nextId} class="next" aria-label="次へ"></span>
  </div>
)}




<style
  define:vars={{
    prevDecoration: `url(${prevDecorationImgSrc.src})`,
  }}
>
  ul {
    padding: 0;
    margin: 0;
  }

  li {
    list-style: none;
  }

  .article-wrapper img {
    width: 95%;
    height: auto;
  }

  .slide-wrapper {
    position: relative;
    max-width: 340px;
    height: auto;
    max-lines: 500px;
    margin: 0 auto 40px;
  }


.slide {
  display: flex;
  width: 100%;
  height: 100%;
  transition: transform 0.4s ease;
}

.slide div {
  flex: 0 0 auto;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.slide .card-contents{
  width: 300px;
  display: flex;
  flex-flow: column;
      border: 8px solid var(--white);
    border-radius: 8px;
    box-shadow: 0 0 8px 0 rgb(202 202 202 / 60%);
}

.contents img{
  width: 100%;
  height: 170px;
  object-fit: cover;
  border-radius: 8px 8px 0 0;
}

.textarea{
  display: flex;
  flex-flow: column;
}

  .next {
    position: absolute;
    right: -23px;
    bottom: 45%;
    z-index: 5;
    width: 50px;
    height: 50px;
    cursor: pointer;
    background-image: var(--prevDecoration);
    background-size: cover;
    rotate: 180deg;
  }

  .prev {
    position: absolute;
    bottom: 45%;
    left: -25px;
    z-index: 5;
    width: 50px;
    height: 50px;
    cursor: pointer;
    background-image: var(--prevDecoration);
    background-size: cover;
  }

  .card{
    display: block;
    background: white;
    border-radius: 14px;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(0, 0, 0, .06);
  }

  .slide .textarea{
    padding: 12px 14px 16px;
    text-align: left;
    display: block;
    height: 170px;
    color: #ff8219;
  }

  .slide h2{
    margin: 8px 0 8px;
    font-size: 18px;
    line-height: 1.3;
    padding-left: 14px;
  }
  
  .slide .date{
    font-size: 14px;
    color: #989898;
    text-align: left;
    display: block;
    padding-top: 12px;
    padding-left: 14px;

  }

  .slide .excerpt{
    width: 90%;
    margin: 0 auto;
    color: #333;
  }

  @media screen and (max-width: 600px) {
  .next {
    width: 30px;
    height: 30px;
    bottom: 38%;
  }
  .prev{
    width: 30px;
    height: 30px;
    bottom: 38%;
  }
  }

  

</style>

<script is:inline define:vars={{ slideId, prevId, nextId }}>
const slide = document.getElementById(slideId);
const prev = document.getElementById(prevId);
const next = document.getElementById(nextId);

if (!slide || !prev || !next) {
  console.warn("carousel elements not found");
} else {
  const slides = slide.querySelectorAll(".article-wrapper");

  const realSlideCount = slides.length - 2;
  let index = 1;
  let isAnimating = false;

  function move() {
    isAnimating = true;
    slide.style.transform = `translateX(${-100 * index}%)`;
  }

  slide.style.transform = "translateX(-100%)";

  slide.addEventListener("transitionend", () => {

    if (index === realSlideCount + 1) {
      slide.style.transition = "none";
      index = 1;
      slide.style.transform = `translateX(${-100 * index}%)`;
      slide.offsetHeight; // reflow
      slide.style.transition = "transform 0.4s ease";
    }

    if (index === 0) {
      slide.style.transition = "none";
      index = realSlideCount;
      slide.style.transform = `translateX(${-100 * index}%)`;
      slide.offsetHeight;
      slide.style.transition = "transform 0.4s ease";
    }

    isAnimating = false;
  });

  function goNext() {
    if (isAnimating) return;
    index++;
    move();
  }

  function goPrev() {
    if (isAnimating) return;
    index--;
    move();
  }

  next.addEventListener("click", goNext);
  prev.addEventListener("click", goPrev);
}
</script>