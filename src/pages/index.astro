---
import Slider from "../pages/_components/top-page/slider.astro";
import { Image, getImage } from "astro:assets";
import keyImg from "../assets/top-logo2.png";
import titleLogo1 from "../assets/BestSpotsLogo.png";
import titleLogo2 from "../assets/EventLogo.png";
import titleLogo3 from "../assets/NewsLogo.png";
import backGroundImg from "../assets/background-kagoshima.png";
import { fetchPostsByCategorySlug } from "../lib/wp/categories";
import footerImg from "../assets/pass2.png";
const footerImgSrc = await getImage({ src: footerImg });

const wp = import.meta.env.WORDPRESS_DOMAIN;

// WordPressカテゴリslug（WP側で設定したslug）
const latestPosts = await fetchPostsByCategorySlug(wp, "latest", 10);
const spotPosts   = await fetchPostsByCategorySlug(wp, "spots", 10);
const eventPosts  = await fetchPostsByCategorySlug(wp, "events", 10);
const backGroundImgSrc = await getImage({ src: backGroundImg });
const res = await fetch(`${wp}/wp-json/wp/v2/posts?per_page=10&_embed=1`);
const posts = await res.json();


---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Study in Kagoshima</title>
  </head>

  <body>

    <main>
      <div class="first-view">
      <Image alt="キービジュアルロゴ" src={keyImg}/>
      </div>
      <div class="container">
        <div class="slider-wrapper">
          <div class="title">
            <Image alt="タイトルロゴ" src={titleLogo1}/>
          </div>
          <Slider idPrefix="spots" posts={spotPosts} />
        </div>
        <div class="slider-wrapper">
          <div class="title">
            <Image alt="タイトルロゴ" src={titleLogo2}/>
          </div>
          <Slider idPrefix="events" posts={eventPosts} />
        </div>
        <div class="slider-wrapper">
          <div class="title">
            <Image alt="タイトルロゴ" src={titleLogo3}/>
          </div>
          <Slider idPrefix="latest" posts={latestPosts} />
        </div>
      </div>
    </main>
    <footer class="footer-bottom">
      <small class="footer__copyright">
          © 2026 Kagoshima portal — Portfolio Project
        </small>
    </footer>


  </body>
</html>

<style
  define:vars={{
    backGround: `url(${backGroundImgSrc.src})`,
    footerImg: `url(${footerImgSrc.src})`,

    
  }}
>
      body { margin: 0; font-family: system-ui, -apple-system, sans-serif; background: #f6f6f6; }
      .header { padding: 32px 16px; background: white; border-bottom: 1px solid #eee; }
      .header h1 { margin: 0; font-size: 24px; }
      .header p { margin: 8px 0 0; color: #666; }

      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; }
      .card { display: block; background: white; border-radius: 14px; overflow: hidden; color: inherit; text-decoration: none; box-shadow: 0 6px 20px rgba(0,0,0,.06); }
      .card img, .dummy { width: 100%; height: 160px; object-fit: cover; background: #ddd; }
      .content { padding: 12px 14px 16px; }
      .date { font-size: 12px; color: #888; }
      h2 { margin: 8px 0 8px; font-size: 18px; line-height: 1.3; }
      .excerpt { margin: 0; color: #555; font-size: 14px; line-height: 1.6; }
      .excerpt :global(p) { margin: 0; } /* WP excerptは<p>が入る */
      .first-view{
        background: var(--backGround) center center / cover no-repeat;
        width: 100%;
        height: 100vh;
        position: relative;
        /* border-top: 15px solid #FF8219; */
        border-bottom: 15px solid #FF8219;
        box-sizing: border-box;
      }

      .first-view img{
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        display: block;
        width: 550px;
        height: auto;
      }
      
      .container { 
        max-width: 980px; 
        margin: 0 auto; 
        padding: 16px; 
        overflow: hidden;
      }

      .title img{
        height: 100px;
        width: auto;
      }

      .footer-bottom{
        background: #000;
    text-align: center;
    background: #FF8219;
    padding-bottom: 17px;
    margin-top: 62px;
    position: relative;
    vertical-align: top;
    margin-top: 236px;
      }

    .footer-bottom::before{
      content: "";
      width: 100%;
    position: absolute;
    background-image: var(--footerImg);
        height: 120px;
        /* bottom: 0; */
        /* left: 0; */
        background-position: left center;
        background-repeat: repeat-x;
        background-size: contain;
        top: -118px;
        left: 0;
    }

  @media screen and (max-width: 1030px) {
    .container { 
        max-width: 100%; 
        margin-top: 40px;
      }
    .title img{
      height: 70px;
    }
  }

  @media screen and (max-width: 600px) {
    .first-view img{
        width: 300px;
      }

    .footer-bottom{
      margin-top: 140px;
    }
  }


    </style>